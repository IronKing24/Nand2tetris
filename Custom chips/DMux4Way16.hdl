/**
Function: if (sel = 00) then {a,b,c,d,} = {1,0,0,0}
          else if (sel = 01) then {a,b,c,d,} = {0,1,0,0}
          else if (sel = 10) then {a,b,c,d,} = {0,0,1,0}
          else if (sel = 11) then {a,b,c,d,} = {0,0,0,1}
*/

CHIP DMux4Way16 {

    IN in[16], sel[2];
    OUT a[16], b[16], c[16], d[16];
    PARTS:
    DMux16(in=in, sel=sel[1], a=dmuxaa, b=dmuxab);
    DMux16(in=dmuxaa, sel=sel[0], a=a, b=b);
    DMux16(in=dmuxab, sel=sel[0], a=c, b=d);
}