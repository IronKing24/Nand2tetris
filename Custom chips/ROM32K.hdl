/**
Function: Emits the 16-bit value stored in the adress selected by the adress input.
It is assumed that the chip is preloaded with a program written in Hack machine language. 
*/

CHIP ROM32K {
    IN address[15];
    OUT out[16];

    PARTS:
    RAM16K(address=address[0..13],out=rom0);
    RAM16K(address=address[0..13],out=rom1);
    Mux16(a=rom0,b=rom1,sel=address[14],out=out);
}