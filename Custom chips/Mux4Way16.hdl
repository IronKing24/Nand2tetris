/**
Function: if (sel = 00,01,10, or 11) then out = a,b,c, or d
comment: the assingment is a 16 bit opration.
         example, "out=a" means "for i=0..15 out[i]=a[i]"
*/

CHIP Mux4Way16 {

    IN a[16], b[16], c[16], d[16], sel[2];
    OUT out[16];
    PARTS:
    Mux16(a=a,b=b,sel=sel[0], out=mux0);
    Mux16(a=c,b=d,sel=sel[0], out=mux1);
    Mux16(a=mux0,b=mux1,sel=sel[1], out=out);
}